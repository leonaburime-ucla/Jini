{
  "name": "jini",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": "~24",
    "pnpm": ">=10.33.2 <11"
  },
  "scripts": {
    "guard": "tsx ./scripts/guard.ts",
    "playground": "tsx ./scripts/start-playground.ts",
    "playground:web": "tsx ./scripts/start-playground.ts --web-only",
    "playground:desktop": "pnpm --filter @jini-app/reference-desktop run build && pnpm --filter @jini-app/reference-desktop run dev",
    "typecheck": "pnpm -r --if-present run typecheck && tsc -p scripts/tsconfig.json --noEmit",
    "changeset": "changeset"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "electron", "node-pty"]
  }
}
