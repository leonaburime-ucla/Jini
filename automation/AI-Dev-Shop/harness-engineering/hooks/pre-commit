#!/usr/bin/env bash
# Speckit pre-commit hook — runs fast validation checks.
# Install with: bash harness-engineering/hooks/install-hooks.sh
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
exec bash "$ROOT_DIR/harness-engineering/validators/run-all.sh" --profile precommit
