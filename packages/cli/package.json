{
  "name": "@jini/cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/leonaburime-ucla/Jini.git", "directory": "packages/cli" },
  "type": "module",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "bin": { "jini": "./dist/main.js" },
  "files": ["dist"],
  "publishConfig": { "access": "restricted", "registry": "https://registry.npmjs.org" },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@jini/core": "workspace:*",
    "@jini/sidecar": "workspace:*"
  }
}
