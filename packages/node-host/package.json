{
  "name": "@jini/node-host",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "repository": { "type": "git", "url": "https://github.com/leonaburime-ucla/Jini.git", "directory": "packages/node-host" },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": { "access": "restricted", "registry": "https://registry.npmjs.org" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@jini/agent-runtime": "workspace:*",
    "@jini/core": "workspace:*",
    "@jini/daemon": "workspace:*",
    "@jini/http": "workspace:*",
    "@jini/media": "workspace:*",
    "@jini/memory": "workspace:*",
    "@jini/sidecar": "workspace:*",
    "@jini/sqlite": "workspace:*",
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@vitest/coverage-v8": "^2.1.9"
  }
}
